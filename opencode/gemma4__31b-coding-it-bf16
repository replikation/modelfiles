# 1. BASE MODEL
FROM gemma4:31b-it-bf16

# 2. CONTEXT & PERFORMANCE TUNING
# Utilizing native high-context capabilities safely.
PARAMETER num_ctx 262144
# PARAMETER num_predict 4096      # Max tokens to generate per response, optional
# PARAMETER num_thread 16         # Adjust based on your CPU/system architecture, optional

# 3. SAMPLING & REASONING TUNING
# Values tailored for creative/reasoning balance.
PARAMETER temperature 1.0 # optional
PARAMETER top_p 0.95 # optional
PARAMETER top_k 64 # optional
# PARAMETER repeat_penalty 1.1 # optional